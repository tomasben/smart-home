every 12:00 do
    aire_habitacion.temp_obj = 30°C
    persiana_cuarto.posicion = 10%
    foco_sala.brillo = 100%
end

when sensor_temp > 50°C do
    foco_sala.estado = off
    altavoz_salon.mute = off
    aire_habitacion.temp_obj = 17°C
end

when sensor_movimiento == true do
    alarma_casa.activada = on
end

when sensor_movimiento == TRUE do
    altavoz_sala.email_notif = adonaip2710@gmail.com
end